        <apply>
          <minus/>
          <apply>
            <plus/>
            <apply>
              <times/>
              <apply>
                <divide/>
                <cn cellml:units="dimensionless">1</cn>
                <apply>
                  <times/>
                  <ci>Vol</ci>
                  <ci>c_bulk</ci>
                </apply>
