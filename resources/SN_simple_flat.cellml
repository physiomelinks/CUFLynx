        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>Ca_ER_pre</ci>
        </apply>
        <apply>
          <minus/>
          <apply>
            <plus/>
            <apply>
              <times/>
              <apply>
                <divide/>
                <cn cellml:units="dimensionless">1</cn>
                <apply>
                  <times/>
                  <ci>Vol</ci>
                  <ci>c_ER_pre</ci>
                </apply>
              </apply>
              <apply>
                <minus/>
                <apply>
                  <minus/>
                  <apply>
                    <minus/>
                    <ci>j_SERCA</ci>
                  </apply>
                  <ci>j_leak_Ca</ci>
                </apply>
                <ci>j_diffCa_ER</ci>
              </apply>
            </apply>
            <apply>
              <times/>
              <ci>k_unbind_Ca_ER</ci>
              <ci>CaB_Ca_ER_pre</ci>
            </apply>
          </apply>
          <apply>
            <times/>
            <ci>k_bind_Ca_ER</ci>
            <ci>Ca_ER_pre</ci>
            <ci>B_Ca_ER_pre</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>Ca_ER</ci>
        </apply>
        <apply>
          <times/>
          <apply>
            <divide/>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <times/>
              <ci>Vol</ci>
              <ci>c_ER</ci>
            </apply>
          </apply>
          <apply>
            <plus/>
            <apply>
              <minus/>
              <apply>
                <minus/>
                <ci>j_IP3</ci>
              </apply>
              <ci>j_RyR</ci>
            </apply>
            <ci>j_diffCa_ER</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>j_NaCa_Na</ci>
        <apply>
          <times/>
          <apply>
            <divide/>
            <apply>
              <times/>
              <apply>
                <minus/>
                <cn cellml:units="dimensionless">3</cn>
              </apply>
              <ci>i_NaCa</ci>
            </apply>
            <ci>F</ci>
          </apply>
          <cn type="e-notation" cellml:units="nanoA_per_A">1<sep/>-9</cn>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>j_NaK_Na</ci>
        <apply>
          <times/>
          <apply>
