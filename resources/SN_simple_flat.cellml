        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>h_Na1_6_inf</ci>
        <apply>
          <divide/>
          <cn cellml:units="dimensionless">1</cn>
          <apply>
            <plus/>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <exp/>
              <apply>
                <divide/>
                <apply>
                  <plus/>
                  <ci>V</ci>
