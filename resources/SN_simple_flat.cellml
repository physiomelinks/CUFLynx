  <component name="axon_SN_module">
    <variable name="t" units="second" interface="public"/>
    <variable name="C" units="picoF" interface="public"/>
    <variable name="R" units="megaOhm" interface="public"/>
    <variable name="V_in" units="milliV" interface="public"/>
    <variable name="I" units="nC_per_s" interface="public"/>
    <variable name="V_rest_approx" units="milliV" interface="public"/>
    <variable name="V" units="milliV" initial_value="V_rest_approx" interface="public"/>
    <variable name="channel_ratio" units="dimensionless" interface="public"/>
    <variable name="I_channels" units="nC_per_s" interface="public"/>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>I</ci>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>V_in</ci>
            <ci>V</ci>
          </apply>
          <ci>R</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>I_channels</ci>
        <apply>
          <times/>
          <ci>I</ci>
          <ci>channel_ratio</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>V</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <times/>
            <cn type="e-notation" cellml:units="milliV_per_kiloV">1<sep/>6</cn>
            <apply>
              <plus/>
              <ci>I</ci>
              <ci>I_channels</ci>
            </apply>
          </apply>
          <ci>C</ci>
        </apply>
      </apply>
    </math>
  </component>
